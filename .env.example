# Carpeta donde la app buscará/guardará audios y PDFs.
# Si no se define, se usará ./music dentro del proyecto.
MUSIC_DIR=/Users/raquel/Music/MusicLyricsManager

# Ruta al proyecto quitar-voz (solo necesario fuera de Docker con compose).
# QUITAR_VOZ_PATH=/Users/raquel/quitar-voz

# Python con dependencias de quitar-voz. En Docker no hace falta: usa python3 del contenedor.
# PYTHON_PATH=python3

# Modelo de separación de voz: fast (UVR-MDX-NET, recomendado en CPU) o quality (MDX23C, muy lento).
SEPARATION_MODEL=fast
